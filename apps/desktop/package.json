    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^14.0.0",
    "jsdom": "^26.1.0",
    "katex": "^0.16.40",
    "postcss": "^8.4.0",
