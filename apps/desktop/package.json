    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@research-copilot/types": "workspace:*",
    "@research-copilot/ui": "workspace:*",
    "@tauri-apps/api": "^2.6.0",
