{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小妍",
  "identifier": "com.researchcopilot.desktop",
  "version": "0.4.3",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "resources": {
      "zh-Hans.lproj": "zh-Hans.lproj",
      "zh_CN.lproj": "zh_CN.lproj",
      "resources/ccfddl.json": "resources/ccfddl.json"
    },
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "offlineInstaller"
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "小妍",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 12,
          "y": 16
        },
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyRTdENTE4QTYwQzlCRUQKUldUdG13eW1HTlhub2l6bFZCM0RHeWF0ME1KZzBHZkZoWVE0L0ZNUDJnSGNOS3dlQml0WGJrRzMK",
      "endpoints": [
        "https://pub-9c3110eb71b241e5a88d8aa3388af9a2.r2.dev/updaters/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
