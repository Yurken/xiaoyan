{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResearchCopilot",
  "identifier": "com.researchcopilot.desktop",
  "version": "0.2.8",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "resources": {
      "zh-Hans.lproj": "zh-Hans.lproj",
      "zh_CN.lproj": "zh_CN.lproj"
    },
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "offlineInstaller"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "智研 Copilot",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3MzgzRURCMzRBMkMzMjUKUldRbHc2STAyejQ0OTY3M2FJSTlpMmxJMTNCR1B3RGVCUzhsNkp1T05CQTNCOEI2M3UvR3ZRa08K",
      "endpoints": [
        "http://66.42.97.41/research-copilot-updates/latest.json"
      ],
      "dangerousInsecureTransportProtocol": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
