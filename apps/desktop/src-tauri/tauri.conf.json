{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "智研 Copilot",
  "identifier": "com.researchcopilot.app",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "智研 Copilot",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": { "open": true },
    "dialog": {},
    "fs": {
      "scope": { "allow": [{ "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }] }
    }
  }
}
