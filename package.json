{
  "name": "research-copilot",
  "version": "0.3.2",
  "private": true,
  "scripts": {
    "dev:web": "turbo run dev --filter=@research-copilot/web",
    "dev:desktop": "pnpm --dir apps/desktop run dev",
    "build:web": "turbo run build --filter=@research-copilot/web",
    "build:desktop": "pnpm --dir apps/desktop run tauri build",
    "build:updater:mac": "bash scripts/build-mac-updater-upload.sh",
    "build:updater:win": "powershell -ExecutionPolicy Bypass -File scripts/build-win-updater-upload.ps1",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "tauri": "pnpm --dir apps/desktop run tauri"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
