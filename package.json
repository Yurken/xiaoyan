{
  "name": "research-copilot",
  "version": "0.5.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev:web": "turbo run dev --filter=@research-copilot/web",
    "dev:desktop": "pnpm --dir apps/desktop run dev",
    "build:web": "turbo run build --filter=@research-copilot/web",
    "build:desktop": "pnpm --dir apps/desktop run tauri build",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "pnpm --dir apps/desktop run test:e2e",
    "tauri": "pnpm --dir apps/desktop run tauri",
    "deploy:all": "node scripts/release-sync-landing.mjs --deploy-all",
    "release:landing": "node scripts/release-sync-landing.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
