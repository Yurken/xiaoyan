# =============================
# Database
# =============================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/research_copilot

# =============================
# LLM Provider: "openai" | "anthropic" | "openai_compatible"
# =============================
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022

# --- OpenAI-Compatible (e.g. DeepSeek, Moonshot, SiliconFlow) ---
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1
# OPENAI_COMPATIBLE_API_KEY=sk-...
# OPENAI_COMPATIBLE_CHAT_MODEL=deepseek-chat
# OPENAI_COMPATIBLE_EMBEDDING_MODEL=BAAI/bge-m3

# =============================
# RAG
# =============================
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=5

# =============================
# File Upload
# =============================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# =============================
# CORS (comma-separated origins)
# =============================
CORS_ORIGINS=http://localhost:3000

# =============================
# Literature Search (Semantic Scholar public API, no key needed)
# =============================
SEMANTIC_SCHOLAR_API_KEY=
